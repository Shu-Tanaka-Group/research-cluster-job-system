{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_CJOB_DB",
      "label": "CJob DB",
      "description": "CJob PostgreSQL data source",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-postgresql-datasource",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "概要",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "CPU フレーバーの使用率。赤色の場合、CPU ジョブの待ち時間が長くなる可能性があります。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.85 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "expr": "kueue_cluster_queue_resource_usage{cluster_queue=\"cjob-cluster-queue\", flavor=\"cpu-flavor\", resource=\"cpu\"}\n/\nkueue_cluster_queue_nominal_quota{cluster_queue=\"cjob-cluster-queue\", flavor=\"cpu-flavor\", resource=\"cpu\"}",
          "legendFormat": "CPU 使用率",
          "refId": "A"
        }
      ],
      "title": "CPU 使用率",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "GPU フレーバーの使用率。GPU は台数が限られているため、混雑しやすいです。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.75 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "expr": "kueue_cluster_queue_resource_usage{cluster_queue=\"cjob-cluster-queue\", flavor=\"gpu-flavor\", resource=\"nvidia.com/gpu\"}\n/\nkueue_cluster_queue_nominal_quota{cluster_queue=\"cjob-cluster-queue\", flavor=\"gpu-flavor\", resource=\"nvidia.com/gpu\"}",
          "legendFormat": "GPU 使用率",
          "refId": "A"
        }
      ],
      "title": "GPU 使用率",
      "type": "gauge"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_CJOB_DB}" },
      "description": "DB 上で待機中のジョブ数（QUEUED + DISPATCHING + DISPATCHED）。0 なら投入したジョブはすぐ実行開始されます。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"待機中\" FROM jobs WHERE status IN ('QUEUED', 'DISPATCHING', 'DISPATCHED');",
          "refId": "A"
        }
      ],
      "title": "待機中ジョブ数",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "直近 1 時間に投入されたジョブの待ち時間（中央値）。今投入した場合のおおよその待ち時間の目安です。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(kueue_admission_wait_time_seconds_bucket{cluster_queue=\"cjob-cluster-queue\"}[1h]))",
          "legendFormat": "P50",
          "refId": "A"
        }
      ],
      "title": "推定待ち時間 (P50)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "キューの状態",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "実行中ワークロードと待機中ワークロードの推移。待機中が増加傾向なら混雑しています。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "実行中" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "待機中" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "kueue_admitted_active_workloads{cluster_queue=\"cjob-cluster-queue\"}",
          "legendFormat": "実行中",
          "refId": "A"
        },
        {
          "expr": "kueue_pending_workloads{cluster_queue=\"cjob-cluster-queue\"}",
          "legendFormat": "待機中",
          "refId": "B"
        }
      ],
      "title": "キュー内ジョブ数の推移",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_CJOB_DB}" },
      "description": "時間帯ごとのジョブ投入数と完了数。完了が投入に追いついていれば健全です。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', created_at) AS time,\n  COUNT(*) AS \"投入\"\nFROM jobs\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1;",
          "refId": "A"
        },
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', finished_at) AS time,\n  COUNT(*) AS \"完了\"\nFROM jobs\nWHERE $__timeFilter(finished_at)\n  AND status IN ('SUCCEEDED', 'FAILED')\nGROUP BY 1\nORDER BY 1;",
          "refId": "B"
        }
      ],
      "title": "ジョブ投入・完了の推移",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 102,
      "title": "CPU リソースの詳細",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "CPU コアの使用量とクォータ上限。上限に近いほど新規ジョブの待ち時間が長くなります。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "コア数",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "クォータ上限" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 13 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "kueue_cluster_queue_resource_usage{cluster_queue=\"cjob-cluster-queue\", flavor=\"cpu-flavor\", resource=\"cpu\"}",
          "legendFormat": "使用中",
          "refId": "A"
        },
        {
          "expr": "kueue_cluster_queue_nominal_quota{cluster_queue=\"cjob-cluster-queue\", flavor=\"cpu-flavor\", resource=\"cpu\"}",
          "legendFormat": "クォータ上限",
          "refId": "B"
        }
      ],
      "title": "CPU 使用量の推移",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "メモリ使用量とクォータ上限（GiB）。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "GiB",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "クォータ上限" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 13 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "kueue_cluster_queue_resource_usage{cluster_queue=\"cjob-cluster-queue\", flavor=\"cpu-flavor\", resource=\"memory\"} / 1024 / 1024 / 1024",
          "legendFormat": "使用中",
          "refId": "A"
        },
        {
          "expr": "kueue_cluster_queue_nominal_quota{cluster_queue=\"cjob-cluster-queue\", flavor=\"cpu-flavor\", resource=\"memory\"} / 1024 / 1024 / 1024",
          "legendFormat": "クォータ上限",
          "refId": "B"
        }
      ],
      "title": "メモリ使用量の推移",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 103,
      "title": "GPU リソースの詳細",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "GPU 使用量。上限に達している場合、GPU ジョブは待機状態になります。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "GPU 数",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "max": 5,
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "クォータ上限" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "kueue_cluster_queue_resource_usage{cluster_queue=\"cjob-cluster-queue\", flavor=\"gpu-flavor\", resource=\"nvidia.com/gpu\"}",
          "legendFormat": "使用中",
          "refId": "A"
        },
        {
          "expr": "kueue_cluster_queue_nominal_quota{cluster_queue=\"cjob-cluster-queue\", flavor=\"gpu-flavor\", resource=\"nvidia.com/gpu\"}",
          "legendFormat": "クォータ上限",
          "refId": "B"
        }
      ],
      "title": "GPU 使用量の推移",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "GPU ノード上の CPU 使用量。GPU が空いていても CPU が不足すると GPU ジョブが待機する場合があります。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "コア数",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "クォータ上限" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "kueue_cluster_queue_resource_usage{cluster_queue=\"cjob-cluster-queue\", flavor=\"gpu-flavor\", resource=\"cpu\"}",
          "legendFormat": "使用中",
          "refId": "A"
        },
        {
          "expr": "kueue_cluster_queue_nominal_quota{cluster_queue=\"cjob-cluster-queue\", flavor=\"gpu-flavor\", resource=\"cpu\"}",
          "legendFormat": "クォータ上限",
          "refId": "B"
        }
      ],
      "title": "GPU ノード CPU 使用量",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 104,
      "title": "待ち時間の分析",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "ジョブが投入されてから実行開始されるまでの待ち時間。P50 は半数のジョブがこの時間以内に開始されたことを示します。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 27 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(kueue_admission_wait_time_seconds_bucket{cluster_queue=\"cjob-cluster-queue\"}[30m]))",
          "legendFormat": "P50（中央値）",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(kueue_admission_wait_time_seconds_bucket{cluster_queue=\"cjob-cluster-queue\"}[30m]))",
          "legendFormat": "P95",
          "refId": "B"
        }
      ],
      "title": "待ち時間の推移 (P50 / P95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_CJOB_DB}" },
      "description": "直近のジョブの実際の待ち時間。自分と似たリソース要求のジョブがどの程度待ったか参考にできます。",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": [
